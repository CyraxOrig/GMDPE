{
    "geode": ">=5.7.1",
    "gd": {
        "win": "2.2081",
        "android": "2.2081"
    },
    "id": "cyraxorig.gmdpe",
    "name": "GMDPE",
    "version": "v1.0.0",
    "developer": "CyraxOrig",
    "description": "Geometry More Dash Physical Extension — hack menu with 20+ features.",
    "tags": ["gameplay", "cheats", "enhancement"],
    "settings": {
        "gameplay-title": { "type": "title", "name": "🎮 Gameplay" },

        "noclip": {
            "type": "bool", "name": "Noclip",
            "description": "Pass through all obstacles.", "default": false
        },
        "noclip-opacity": {
            "type": "float", "name": "Noclip Opacity",
            "description": "Player opacity while noclip is active.",
            "default": 0.5, "min": 0.0, "max": 1.0,
            "control": { "slider": true }, "enable-if": "noclip"
        },
        "straight-fly": {
            "type": "bool", "name": "Straight Fly",
            "description": "Lock ship to a straight horizontal line.", "default": false
        },
        "straight-fly-smoothness": {
            "type": "float", "name": "Straight Fly Smoothness",
            "description": "1.0 = instant lock, 0.0 = very gradual.",
            "default": 1.0, "min": 0.01, "max": 1.0,
            "control": { "slider": true }, "enable-if": "straight-fly"
        },
        "respawn-bypass": {
            "type": "bool", "name": "Instant Respawn",
            "description": "Skip death animation.", "default": false
        },
        "hide-player": {
            "type": "bool", "name": "Hide Player",
            "description": "Make your icon invisible.", "default": false
        },
        "solid-wave-trail": {
            "type": "bool", "name": "Solid Wave Trail",
            "description": "Replace dotted wave trail with solid line.", "default": false
        },
        "no-death-effects": {
            "type": "bool", "name": "No Death Effects",
            "description": "Disable explosion particles on death.", "default": false
        },

        "performance-title": { "type": "title", "name": "⚡ Performance" },

        "speedhack": {
            "type": "bool", "name": "Speedhack",
            "description": "Change game speed.", "default": false
        },
        "speedhack-value": {
            "type": "float", "name": "Speed Multiplier",
            "description": "1.0 = normal speed.",
            "default": 1.0, "min": 0.1, "max": 10.0,
            "control": { "slider": true }, "enable-if": "speedhack"
        },
        "fps-bypass": {
            "type": "bool", "name": "FPS Bypass",
            "description": "Unlock frame rate above 240.", "default": false
        },
        "fps-value": {
            "type": "int", "name": "FPS Limit",
            "description": "Target FPS.",
            "default": 360, "min": 60, "max": 1000,
            "control": { "slider": true }, "enable-if": "fps-bypass"
        },
        "tps-bypass": {
            "type": "bool", "name": "TPS Bypass",
            "description": "Decouple physics ticks from FPS.", "default": false
        },
        "tps-value": {
            "type": "int", "name": "TPS Value",
            "description": "Physics ticks per second.",
            "default": 240, "min": 60, "max": 1000,
            "control": { "slider": true }, "enable-if": "tps-bypass"
        },

        "visual-title": { "type": "title", "name": "👁 Visual" },

        "show-hitboxes": {
            "type": "bool", "name": "Show Hitboxes",
            "description": "Render hitboxes of all objects.", "default": false
        },
        "show-cps": {
            "type": "bool", "name": "CPS Counter",
            "description": "Show clicks per second on screen.", "default": false
        },
        "show-attempts": {
            "type": "bool", "name": "Show Attempts",
            "description": "Show attempt number on screen.", "default": true
        },
        "show-noclip-deaths": {
            "type": "bool", "name": "Noclip Death Counter",
            "description": "Count how many times you would have died.", "default": false
        },

        "misc-title": { "type": "title", "name": "🔧 Misc" },

        "practice-music-sync": {
            "type": "bool", "name": "Practice Music Sync",
            "description": "Play music from correct position in practice mode.", "default": false
        },
        "auto-clicker": {
            "type": "bool", "name": "Auto Clicker",
            "description": "Automatically click at set interval.", "default": false
        },
        "auto-clicker-cps": {
            "type": "float", "name": "Auto Clicker CPS",
            "description": "Clicks per second.",
            "default": 10.0, "min": 1.0, "max": 60.0,
            "control": { "slider": true }, "enable-if": "auto-clicker"
        }
    }
}
